{
  "name": "agone",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite dev",
    "dev:clean": "fuser -k 5173/tcp 5174/tcp 2>/dev/null; sleep 0.5 && vite dev",
    "build": "vite build",
    "start": "BODY_SIZE_LIMIT=${BODY_SIZE_LIMIT:-100M} node build/index.js",
    "preview": "vite preview",
    "check": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
    "check:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
    "db:start": "surreal start --user root --pass root --bind 127.0.0.1:8000 rocksdb://.surrealdata",
    "db:export": "bun run scripts/db-export.ts",
    "db:export:schema": "bun run scripts/db-export.ts --only-schemas",
    "db:import:cloud": "bun run scripts/db-import-cloud.ts",
    "schema": "bun run scripts/apply-schema.ts",
    "seed": "bun run scripts/seed.ts"
  },
  "devDependencies": {
    "@fontsource-variable/oswald": "^5.2.5",
    "@fontsource-variable/roboto": "^5.2.10",
    "@internationalized/date": "^3.12.1",
    "@lucide/svelte": "^1.16.0",
    "@sveltejs/adapter-node": "^5.5.4",
    "@sveltejs/kit": "^2.61.1",
    "@sveltejs/vite-plugin-svelte": "^7.1.2",
    "@tailwindcss/postcss": "^4.3.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/leaflet": "^1.9.21",
    "@types/node": "^26.1.0",
    "dotenv": "^17.4.2",
    "phosphor-svelte": "^3.1.0",
    "shadcn-svelte": "^1.3.0",
    "svelte": "^5.55.9",
    "svelte-check": "^4.4.8",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "typescript": "^6.0.3",
    "vite": "^8.0.14"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.1063.0",
    "@aws-sdk/lib-storage": "^3.1063.0",
    "@tiptap/core": "^3.27.1",
    "@tiptap/starter-kit": "^3.27.1",
    "bits-ui": "^2.18.1",
    "clsx": "^2.1.1",
    "leaflet": "^1.9.4",
    "mysql2": "^3.22.5",
    "pdf-lib": "^1.17.1",
    "resend": "^6.12.4",
    "sharp": "^0.34.5",
    "stripe": "^19.1.0",
    "surrealdb": "^2.0.3",
    "svelte-sonner": "^1.1.1",
    "tailwind-merge": "^3.6.0",
    "tailwind-variants": "^3.2.2",
    "zod": "^4.4.3"
  }
}
