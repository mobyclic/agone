# ── SurrealDB (Cloud ou local) ──
SURREAL_URL="https://<instance>.surreal.cloud/rpc"
SURREAL_NAMESPACE="mobyclic"
SURREAL_DATABASE="agone"
SURREAL_USER="rootuser"
SURREAL_PASS=""

# ── Cloudflare R2 (couvertures publiques + ebooks privés) ──
CLOUDFLARE_ACCOUNT_ID=""
CLOUDFLARE_R2_ACCESS_KEY_ID=""
CLOUDFLARE_R2_SECRET_ACCESS_KEY=""
CLOUDFLARE_R2_BUCKET_NAME="agone"
CLOUDFLARE_R2_PUBLIC_URL="https://<pub-id>.r2.dev"
# CLOUDFLARE_R2_JURISDICTION="eu"

# ── App ──
NODE_ENV="development"
PUBLIC_BASE_URL="http://localhost:5173"
PUBLIC_SITE_NAME="Agone"
BODY_SIZE_LIMIT="10485760"

# ── Mail (Resend) ──
RESEND_API_KEY=""
MAIL_FROM="Agone <onboarding@resend.dev>"
MAIL_REPLY_TO="contact@agone.org"
# Sécurité anti-envoi : en dev, tout part vers MAIL_DRY_RUN_TO
MAIL_DRY_RUN="true"
MAIL_DRY_RUN_TO="you@example.com"

# ── Stripe (paiement des commandes) ──
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
PUBLIC_STRIPE_PUBLISHABLE_KEY=""

# ── Cron (jobs planifiés) ──
CRON_SECRET=""

# ── Belles Lettres (distributeur) — Phase 3 ──
# SÉCURITÉ : l'envoi FTP reste DÉSACTIVÉ tant que le site n'est pas en production.
BL_FTP_ENABLED="false"
BL_FTP_HOST=""
BL_FTP_USER=""
BL_FTP_PASS=""
BL_EXTRANET_USER=""
BL_EXTRANET_PASS=""

# ── Newsletter (Brevo) — optionnel ──
BREVO_API_KEY=""
